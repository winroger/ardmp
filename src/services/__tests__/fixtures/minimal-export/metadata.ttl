@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

<http://example.org/dataset/buildings> a dcat:Dataset ;
  dct:title "Minimal Buildings Dataset" ;
  dct:description "A minimal two-row export fixture for stabilization tests." ;
  dct:issued "2026-05-18" ;
  prov:qualifiedAttribution _:att1 .

_:att1 prov:agent <http://example.org/people/tester> .

<http://example.org/people/tester> a foaf:Person ;
  foaf:name "ARDMP Test User" .
